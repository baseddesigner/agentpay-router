{
  "name": "agentpay-router",
  "version": "0.1.0",
  "description": "x402-style paid HTTP gateway for agent market quotes and KeeperHub handoff previews.",
  "type": "module",
  "bin": {
    "agentpay": "./dist/src/cli.js"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "cli": "tsx src/cli.ts",
    "demo": "tsx examples/agent-demo.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc --noEmit"
  },
  "keywords": [
    "x402",
    "agents",
    "hono",
    "vercel",
    "keeperhub",
    "base"
